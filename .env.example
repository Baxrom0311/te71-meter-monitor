# Meter Monitor — Sozlamalar
# Nusxalab .env deb saqlang: cp .env.example .env

# Backend
DB_PATH=/app/data/meters.db
OTA_DIR=/app/firmware
STATIC_DIR=/frontend

# MQTT (Docker: "mosquitto", local: "localhost")
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Server host (ESP32 firmware uchun — main.cpp ga yozing)
# SERVER_URL=http://192.168.1.100:8000
