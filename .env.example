# Meter Monitor — Sozlamalar
# Nusxalab .env deb saqlang: cp .env.example .env

# Backend
DB_PATH=/app/data/meters.db
DATABASE_URL=sqlite+aiosqlite:////app/data/meters.db
OTA_DIR=/app/firmware
BACKUP_DIR=/app/backups
BACKUP_KEEP_DAYS=14
STATIC_DIR=/frontend
SECRET_KEY=change-me-in-production
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin1234
DEVICE_API_TOKEN=change-device-token
CORS_ORIGINS=*
TRUSTED_HOSTS=*
RATE_LIMIT_PER_MINUTE=120
DEVICE_RATE_LIMIT_PER_MINUTE=600

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
RUN_INLINE_WORKERS=false

# ESP32 HTTP fallback serverlar
PUBLIC_SERVER_URLS=http://192.168.1.100:8000,http://192.168.1.101:8000
