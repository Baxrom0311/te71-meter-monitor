# Meter Monitor — Sozlamalar
# Nusxalab .env deb saqlang: cp .env.example .env

# Backend
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://meter:meter_password@postgres:5432/meter_monitor
OTA_DIR=/app/firmware
BACKUP_DIR=/app/backups
BACKUP_KEEP_DAYS=14
AUDIT_KEEP_DAYS=180
STATIC_DIR=/frontend
SECRET_KEY=change-me-in-production
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin1234
DEVICE_API_TOKEN=change-device-token
CORS_ORIGINS=*
TRUSTED_HOSTS=*
RATE_LIMIT_PER_MINUTE=120
DEVICE_RATE_LIMIT_PER_MINUTE=600
COMMAND_TTL_SEC=3600
COMMAND_MAX_PENDING_PER_DEVICE=20
MAX_VOLTAGE=500
MAX_CURRENT=10000
MAX_PRESSURE_BAR=100
MIN_TEMPERATURE_C=-80
MAX_TEMPERATURE_C=150
WATER_PRESSURE_MIN_BAR=0.5
WATER_BOTTOM_PRESSURE_FOR_TOP_CHECK_BAR=1.0
GAS_PRESSURE_MIN_BAR=0.02
GAS_PRESSURE_MAX_BAR=5.0
ALERT_DEDUPE_SEC=600
ALERT_ESCALATION_AFTER_SEC=300
ALERT_NOTIFICATION_CHANNELS=internal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# Background workers
RUN_INLINE_WORKERS=true

# ESP32 HTTP fallback serverlar
PUBLIC_SERVER_URLS=http://192.168.1.100:8000,http://192.168.1.101:8000
