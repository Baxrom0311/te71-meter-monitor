# Meter Monitor production env template.
# Copy this file to backend/deploy/.env.production and replace all CHANGE_* values.
APP_ENV=production
RUN_INLINE_WORKERS=true
LOG_FORMAT=text

# Paths
DB_PATH=/root/meter_backend/data/meters.db
OTA_DIR=/root/meter_backend/firmware
BACKUP_DIR=/root/meter_backend/backups
STATIC_DIR=/root/meter_backend/frontend

# Security
SECRET_KEY=CHANGE_ME_GENERATE_32_PLUS_RANDOM_CHARS
DEVICE_API_TOKEN=CHANGE_ME_GENERATE_24_PLUS_RANDOM_CHARS
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Retention
DATA_KEEP_DAYS=30
BACKUP_KEEP_DAYS=14
AUDIT_KEEP_DAYS=180

# Alert notifications
ALERT_NOTIFICATION_CHANNELS=internal
ALERT_ESCALATION_AFTER_SEC=300
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# Limits
RATE_LIMIT_PER_MINUTE=120
DEVICE_RATE_LIMIT_PER_MINUTE=600
