# Runtime
APP_ENV=production
APP_NAME=Meter Monitor
APP_VERSION=4.0
STATIC_DIR=/frontend
OTA_DIR=/app/firmware
BACKUP_DIR=/app/backups

# Database
DATABASE_URL=postgresql+asyncpg://meter:change-db-password@postgres:5432/meter_monitor
RUN_INLINE_WORKERS=true

# Security
SECRET_KEY=replace-with-at-least-32-random-characters
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
DEVICE_API_TOKEN=replace-with-at-least-24-random-characters
TEST_DEVICE_API_TOKEN=replace-with-test-token-or-leave-empty
TEST_METER_SERIALS=202032000525
TEST_DEVICE_TTL_SEC=300
CORS_ORIGINS=https://meter.example.uz
TRUSTED_HOSTS=meter.example.uz
ACCESS_TOKEN_TTL_SEC=86400
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_SEC=900
MIN_PASSWORD_LEN=8

# Limits
RATE_LIMIT_PER_MINUTE=120
DEVICE_RATE_LIMIT_PER_MINUTE=600
MAX_REQUEST_BODY_BYTES=26214400
COMMAND_TTL_SEC=3600
COMMAND_MAX_PENDING_PER_DEVICE=20

# Retention
DATA_KEEP_DAYS=30
BACKUP_KEEP_DAYS=14
AUDIT_KEEP_DAYS=180

# Device timing
OFFLINE_SEC=120
TELEMETRY_INTERVAL_SEC=30
STATUS_INTERVAL_SEC=60
COMMAND_POLL_INTERVAL_SEC=10
PUBLIC_SERVER_URLS=https://meter.example.uz

# Optional external building import integration
EXTERNAL_URGANCH_BASE_URL=https://app.urganchshahar.uz
EXTERNAL_URGANCH_USERNAME=
EXTERNAL_URGANCH_PASSWORD=

# Alert defaults
VOLTAGE_MIN=195.0
VOLTAGE_MAX=253.0
FREQUENCY_MIN=49.0
FREQUENCY_MAX=51.0
MAX_VOLTAGE=500.0
MAX_CURRENT=10000.0
MAX_PRESSURE_BAR=100.0
MIN_TEMPERATURE_C=-80.0
MAX_TEMPERATURE_C=150.0
WATER_PRESSURE_MIN_BAR=0.5
WATER_BOTTOM_PRESSURE_FOR_TOP_CHECK_BAR=1.0
GAS_PRESSURE_MIN_BAR=0.02
GAS_PRESSURE_MAX_BAR=5.0
ALERT_DEDUPE_SEC=600
ALERT_ESCALATION_AFTER_SEC=300
ALERT_NOTIFICATION_CHANNELS=internal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
