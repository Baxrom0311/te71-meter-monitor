/**
 * TE71/TE73 Meter Controller — ESP32 + MAX485
 * WiFi: hardcoded "12" / "12345678"
 * Pinlar: GPIO16=RX, GPIO17=TX, GPIO4=DE/RE
 */
#include <Arduino.h>
#include <string.h>
#include <stdlib.h>
#include "soc/soc.h"
#include "soc/rtc_cntl_reg.h"
#include "soc/timer_group_reg.h"
#include "esp_efuse.h"
#include "esp_mac.h"
#include <WiFi.h>
#include <Preferences.h>
#include <HTTPClient.h>
#include <Update.h>

#define FW_VERSION  "1.2.0"

// ── Pinlar ──────────────────────────────────────────────────────────
#define PIN_RX  16
#define PIN_TX  17
#define PIN_DE   4

// ── HDLC ────────────────────────────────────────────────────────────
#define SERVER_ADDR     0x03
#define CLIENT_PUBLIC   0x21
#define CLIENT_READER   0x03

static const uint8_t LLC_REQ[] = {0xE6, 0xE6, 0x00};
static const uint8_t LLC_RSP[] = {0xE6, 0xE7, 0x00};

// ── OBIS ────────────────────────────────────────────────────────────
static const uint8_t OBIS_RELAY[6]   = {0x00,0x00,0x60,0x03,0x0A,0xFF};
static const uint8_t OBIS_SERIAL[6]  = {0x00,0x00,0x60,0x01,0x00,0xFF};
static const uint8_t OBIS_ENERGY[6]  = {0x01,0x00,0x01,0x08,0x00,0xFF};
static const uint8_t OBIS_VOLT_L1[6] = {0x01,0x00,0x20,0x07,0x00,0xFF};
static const uint8_t OBIS_VOLT_L2[6] = {0x01,0x00,0x34,0x07,0x00,0xFF};
static const uint8_t OBIS_VOLT_L3[6] = {0x01,0x00,0x48,0x07,0x00,0xFF};
static const uint8_t OBIS_CURR_L1[6] = {0x01,0x00,0x1F,0x07,0x00,0xFF};
static const uint8_t OBIS_CURR_L2[6] = {0x01,0x00,0x33,0x07,0x00,0xFF};
static const uint8_t OBIS_CURR_L3[6] = {0x01,0x00,0x47,0x07,0x00,0xFF};
static const uint8_t OBIS_POWER[6]   = {0x01,0x00,0x0F,0x07,0x00,0xFF};
static const uint8_t OBIS_FREQ[6]    = {0x01,0x00,0x0E,0x07,0x00,0xFF};

// ── Holat ────────────────────────────────────────────────────────────
static uint32_t rs485Baud   = 9600;
static bool     isConnected = false;
static uint8_t  clientSrc   = CLIENT_READER;
static uint8_t  sendSeq     = 0;
static uint8_t  recvSeq     = 0;
static uint8_t  invokeId    = 0xC0;

// ── Buferlar ─────────────────────────────────────────────────────────
static uint8_t txBuf[300];
static size_t  txLen;
static uint8_t rxBuf[300];
static size_t  rxLen;
static char    cmdBuf[80];
static uint8_t cmdLen = 0;

// ── WiFi / Config ────────────────────────────────────────────────────
#define WIFI_SSID  "12"
#define WIFI_PASS  "12345678"
#define SERVER_URL "http://67.205.171.93:8100"

static char cfgDeviceId[32]  = "";
static char cfgMeterType[8]  = "TE73";

// ── Taymer ───────────────────────────────────────────────────────────
static unsigned long lastReadingMs  = 0;
static unsigned long lastCmdPollMs  = 0;
static unsigned long lastOtaMs      = 0;
static bool          registeredOk   = false;

#define READING_INTERVAL_MS   30000UL
#define CMD_POLL_INTERVAL_MS  15000UL
#define OTA_CHECK_INTERVAL_MS 3600000UL

// ════════════════════════════════════════════════════════════════════
// FCS16
// ════════════════════════════════════════════════════════════════════
static uint16_t fcsTbl[256];

void initFcs() {
    for (int i = 0; i < 256; i++) {
        uint16_t v = i;
        for (int j = 0; j < 8; j++)
            v = (v & 1) ? ((v >> 1) ^ 0x8408) : (v >> 1);
        fcsTbl[i] = v;
    }
}

uint16_t fcs16(const uint8_t* d, size_t n) {
    uint16_t f = 0xFFFF;
    for (size_t i = 0; i < n; i++)
        f = (f >> 8) ^ fcsTbl[(f ^ d[i]) & 0xFF];
    return f ^ 0xFFFF;
}

// ════════════════════════════════════════════════════════════════════
// HDLC
// ════════════════════════════════════════════════════════════════════
void buildHdlc(uint8_t dest, uint8_t src, uint8_t ctrl,
               const uint8_t* info, size_t infoLen) {
    if (infoLen == 0) {
        uint16_t tot = 7;
        uint8_t fd[5] = {(uint8_t)(0xA0|(tot>>8)),(uint8_t)(tot&0xFF),dest,src,ctrl};
        uint16_t f = fcs16(fd, 5);
        txBuf[0]=0x7E; memcpy(txBuf+1,fd,5);
        txBuf[6]=f&0xFF; txBuf[7]=f>>8; txBuf[8]=0x7E;
        txLen = 9;
    } else {
        uint16_t tot = 9 + (uint16_t)infoLen;
        uint8_t fmt[2] = {(uint8_t)(0xA0|(tot>>8)),(uint8_t)(tot&0xFF)};
        uint8_t hcsIn[5] = {fmt[0],fmt[1],dest,src,ctrl};
        uint16_t hcs = fcs16(hcsIn, 5);
        txBuf[0]=0x7E;
        txBuf[1]=fmt[0]; txBuf[2]=fmt[1];
        txBuf[3]=dest; txBuf[4]=src; txBuf[5]=ctrl;
        txBuf[6]=hcs&0xFF; txBuf[7]=hcs>>8;
        memcpy(txBuf+8, info, infoLen);
        uint16_t fcs = fcs16(txBuf+1, 7+infoLen);
        txBuf[8+infoLen]=fcs&0xFF; txBuf[9+infoLen]=fcs>>8;
        txBuf[10+infoLen]=0x7E;
        txLen = 11 + infoLen;
    }
}

// ════════════════════════════════════════════════════════════════════
// RS-485
// ════════════════════════════════════════════════════════════════════
bool txrx(uint32_t timeoutMs = 3000) {
    while (Serial2.available()) Serial2.read();
    rxLen = 0;
    digitalWrite(PIN_DE, HIGH);
    delayMicroseconds(150);
    Serial2.write(txBuf, txLen);
    Serial2.flush();
    delayMicroseconds(150);
    digitalWrite(PIN_DE, LOW);
    uint32_t t = millis();
    while (millis() - t < timeoutMs) {
        while (Serial2.available() && rxLen < sizeof(rxBuf))
            rxBuf[rxLen++] = Serial2.read();
        if (rxLen > 4 && rxBuf[rxLen-1] == 0x7E) break;
        delay(5);
    }
    return rxLen > 4;
}

const uint8_t* findPdu(size_t* pduLen) {
    for (size_t i = 0; i+2 < rxLen; i++) {
        if (rxBuf[i]==0xE6 && rxBuf[i+1]==0xE7 && rxBuf[i+2]==0x00) {
            int rem = (int)rxLen - (int)i - 3 - 3;
            *pduLen = rem > 0 ? rem : 0;
            return rxBuf + i + 3;
        }
    }
    *pduLen = 0;
    return nullptr;
}

float readDlmsFloat(const uint8_t* d, size_t len) {
    if (len < 2) return NAN;
    switch (d[0]) {
        case 0x05: return (float)(int32_t)(((uint32_t)d[1]<<24)|((uint32_t)d[2]<<16)|((uint32_t)d[3]<<8)|d[4]);
        case 0x06: return (float)(((uint32_t)d[1]<<24)|((uint32_t)d[2]<<16)|((uint32_t)d[3]<<8)|d[4]);
        case 0x12: return (float)(((uint16_t)d[1]<<8)|d[2]);
        case 0x16: return (float)d[1];
        default:   return NAN;
    }
}

void printDlmsValue(const uint8_t* d, size_t len) {
    float v = readDlmsFloat(d, len);
    if (!isnan(v)) { Serial.print((long)v); return; }
    if (len >= 2 && (d[0]==0x09||d[0]==0x0A)) {
        uint8_t slen = d[1];
        for (int i = 0; i < slen && i+2 < (int)len; i++)
            Serial.print((char)d[2+i]);
        return;
    }
    Serial.print("0x");
    for (size_t i = 0; i < len && i < 12; i++) Serial.printf("%02X", d[i]);
}

// ════════════════════════════════════════════════════════════════════
// DLMS Ulanish
// ════════════════════════════════════════════════════════════════════
uint8_t nextCtrl() {
    uint8_t c = ((sendSeq&7)<<5)|0x10|((recvSeq&7)<<1);
    sendSeq = (sendSeq+1)%8;
    recvSeq = (recvSeq+1)%8;
    return c;
}

bool doSnrm() {
    buildHdlc(SERVER_ADDR, clientSrc, 0x93, nullptr, 0);
    return txrx(2000) && rxLen > 4;
}

bool sendAarq(const uint8_t* aarq, size_t alen) {
    uint8_t info[128];
    memcpy(info, LLC_REQ, 3);
    memcpy(info+3, aarq, alen);
    uint8_t ctrl = ((sendSeq&7)<<5)|0x10|((recvSeq&7)<<1);
    buildHdlc(SERVER_ADDR, clientSrc, ctrl, info, 3+alen);
    if (!txrx(3000)) return false;
    for (size_t i = 0; i+4 < rxLen; i++) {
        if (rxBuf[i]==0xA2 && rxBuf[i+1]==0x03 &&
            rxBuf[i+2]==0x02 && rxBuf[i+3]==0x01 && rxBuf[i+4]==0x00) {
            isConnected = true;
            sendSeq = 1; recvSeq = 1; invokeId = 0xC0;
            return true;
        }
    }
    return false;
}

bool connectPublic() {
    clientSrc = CLIENT_PUBLIC;
    sendSeq = 0; recvSeq = 0;
    if (!doSnrm()) return false;
    static const uint8_t aarq[] = {
        0x60,0x1D,
        0xA1,0x09,0x06,0x07,0x60,0x85,0x74,0x05,0x08,0x01,0x01,
        0xBE,0x10,0x04,0x0E,
        0x01,0x00,0x00,0x00,0x06,0x5F,0x1F,0x04,0x00,0x00,0x7E,0x1F,0x04,0xB0
    };
    return sendAarq(aarq, sizeof(aarq));
}

bool connectReader() {
    clientSrc = CLIENT_READER;
    sendSeq = 0; recvSeq = 0;
    if (!doSnrm()) return false;
    static const uint8_t ctos[16] = {
        0x11,0x22,0x33,0x44,0x55,0x66,0x77,0x88,
        0x99,0xAA,0xBB,0xCC,0xDD,0xEE,0xFF,0x00
    };
    uint8_t aarq[72]; size_t p = 0;
    aarq[p++]=0x60; aarq[p++]=0x3E;
    const uint8_t ac[]={0xA1,0x09,0x06,0x07,0x60,0x85,0x74,0x05,0x08,0x01,0x01};
    memcpy(aarq+p,ac,11); p+=11;
    const uint8_t as[]={0x8A,0x02,0x07,0x80}; memcpy(aarq+p,as,4); p+=4;
    const uint8_t mh[]={0x8B,0x07,0x60,0x85,0x74,0x05,0x08,0x02,0x05};
    memcpy(aarq+p,mh,9); p+=9;
    aarq[p++]=0xAC; aarq[p++]=0x12; aarq[p++]=0x80; aarq[p++]=0x10;
    memcpy(aarq+p,ctos,16); p+=16;
    const uint8_t ui[]={0xBE,0x10,0x04,0x0E,
                         0x01,0x00,0x00,0x00,0x06,0x5F,0x1F,0x04,
                         0x00,0x00,0x7E,0x1F,0x04,0xB0};
    memcpy(aarq+p,ui,18); p+=18;
    return sendAarq(aarq, p);
}

void doDisconnect() {
    if (!isConnected) return;
    buildHdlc(SERVER_ADDR, clientSrc, 0x53, nullptr, 0);
    txrx(1000);
    isConnected = false; sendSeq = 0; recvSeq = 0;
}

// ════════════════════════════════════════════════════════════════════
// GET / ACTION
// ════════════════════════════════════════════════════════════════════
bool getAttribute(uint16_t cls, const uint8_t obis[6], uint8_t attr,
                  float* outVal) {
    if (!isConnected) return false;
    uint8_t pdu[13];
    pdu[0]=0xC0; pdu[1]=0x01; pdu[2]=invokeId++;
    pdu[3]=cls>>8; pdu[4]=cls&0xFF;
    memcpy(pdu+5,obis,6); pdu[11]=attr; pdu[12]=0x00;
    uint8_t info[16];
    memcpy(info,LLC_REQ,3); memcpy(info+3,pdu,13);
    buildHdlc(SERVER_ADDR, clientSrc, nextCtrl(), info, 16);
    if (!txrx(3000)) return false;
    size_t plen; const uint8_t* resp = findPdu(&plen);
    if (!resp || plen<5 || resp[0]!=0xC4 || resp[3]!=0x00) return false;
    if (outVal) *outVal = readDlmsFloat(resp+4, plen-4);
    else printDlmsValue(resp+4, plen-4);
    return true;
}

bool doAction(uint16_t cls, const uint8_t obis[6], uint8_t method) {
    if (!isConnected) return false;
    uint8_t pdu[15];
    pdu[0]=0xC3; pdu[1]=0x01; pdu[2]=invokeId++;
    pdu[3]=cls>>8; pdu[4]=cls&0xFF;
    memcpy(pdu+5,obis,6);
    pdu[11]=method; pdu[12]=0x01; pdu[13]=0x0F; pdu[14]=0x00;
    uint8_t info[18];
    memcpy(info,LLC_REQ,3); memcpy(info+3,pdu,15);
    buildHdlc(SERVER_ADDR, clientSrc, nextCtrl(), info, 18);
    if (!txrx(5000)) return false;
    size_t plen; const uint8_t* resp = findPdu(&plen);
    return resp && plen>=4 && resp[0]==0xC7 && resp[3]==0x00;
}

// ════════════════════════════════════════════════════════════════════
// Avtomatik ulanish
// ════════════════════════════════════════════════════════════════════
bool tryConnect(uint32_t baud) {
    Serial2.end(); delay(50);
    Serial2.begin(baud, SERIAL_8N1, PIN_RX, PIN_TX);
    delay(100);
    if (connectReader()) { rs485Baud = baud; return true; }
    doDisconnect();
    if (connectPublic()) { rs485Baud = baud; return true; }
    return false;
}

bool autoConnect() {
    Serial.print("  9600...");
    if (tryConnect(9600)) return true;
    doDisconnect();
    Serial.print(" 4800...");
    if (tryConnect(4800)) return true;
    return false;
}

// ════════════════════════════════════════════════════════════════════
// Device ID
// ════════════════════════════════════════════════════════════════════
void initDeviceId() {
    Preferences prefs;
    prefs.begin("meter", false);
    prefs.getString("devid", cfgDeviceId, sizeof(cfgDeviceId));
    prefs.getString("mtype", cfgMeterType, sizeof(cfgMeterType));
    if (strlen(cfgMeterType) == 0) strcpy(cfgMeterType, "TE73");
    if (strlen(cfgDeviceId) == 0) {
        uint8_t mac[6];
        esp_efuse_mac_get_default(mac);
        snprintf(cfgDeviceId, sizeof(cfgDeviceId),
                 "esp32-%02x%02x%02x%02x%02x%02x",
                 mac[0],mac[1],mac[2],mac[3],mac[4],mac[5]);
        prefs.putString("devid", cfgDeviceId);
    }
    prefs.end();
}

// ════════════════════════════════════════════════════════════════════
// HTTP Backend
// ════════════════════════════════════════════════════════════════════
bool httpPost(const char* path, const String& body) {
    if (WiFi.status() != WL_CONNECTED) return false;
    HTTPClient http;
    char url[200];
    snprintf(url, sizeof(url), "%s%s", SERVER_URL, path);
    http.begin(url);
    http.addHeader("Content-Type", "application/json");
    http.setTimeout(8000);
    int code = http.POST(body);
    http.end();
    return code >= 200 && code < 300;
}

String httpGet(const char* path) {
    if (WiFi.status() != WL_CONNECTED) return "";
    HTTPClient http;
    char url[200];
    snprintf(url, sizeof(url), "%s%s", SERVER_URL, path);
    http.begin(url);
    http.setTimeout(8000);
    int code = http.GET();
    String resp = (code == 200) ? http.getString() : "";
    http.end();
    return resp;
}

void registerDevice() {
    String body = "{\"device_id\":\"";
    body += cfgDeviceId;
    body += "\",\"meter_type\":\"";
    body += cfgMeterType;
    body += "\",\"fw_version\":\"" FW_VERSION "\",\"ip\":\"";
    body += WiFi.localIP().toString();
    body += "\"}";
    if (httpPost("/api/register", body)) {
        registeredOk = true;
        Serial.println("  Backend: ro'yxatdan o'tildi");
    }
}

// ════════════════════════════════════════════════════════════════════
// Meter o'qish va backend ga yuborish
// ════════════════════════════════════════════════════════════════════
void readAndPost() {
    if (!isConnected) {
        Serial.print("  Hisoblagichga ulaning...");
        if (!autoConnect()) { Serial.println(" ULANMADI"); return; }
        Serial.printf(" OK (%u baud)\n", rs485Baud);
    }

    float vl1=NAN, vl2=NAN, vl3=NAN;
    float il1=NAN, il2=NAN, il3=NAN;
    float pw=NAN, freq=NAN, energy=NAN;

    getAttribute(3, OBIS_VOLT_L1, 2, &vl1);
    getAttribute(3, OBIS_VOLT_L2, 2, &vl2);
    getAttribute(3, OBIS_VOLT_L3, 2, &vl3);
    getAttribute(3, OBIS_CURR_L1, 2, &il1);
    getAttribute(3, OBIS_CURR_L2, 2, &il2);
    getAttribute(3, OBIS_CURR_L3, 2, &il3);
    getAttribute(3, OBIS_POWER,   2, &pw);
    getAttribute(3, OBIS_FREQ,    2, &freq);
    getAttribute(3, OBIS_ENERGY,  2, &energy);

    if (!isnan(vl1)) Serial.printf("  U: %.1fV  I: %.3fA  P: %.0fW  F: %.2fHz\n",
                                    vl1/10.0f, il1/1000.0f, pw, freq/100.0f);

    if (WiFi.status() != WL_CONNECTED) return;
    if (!registeredOk) registerDevice();

    String b = "{\"device_id\":\""; b += cfgDeviceId; b += "\"";
    if (!isnan(vl1))    { b += ",\"voltage_l1\":";  b += vl1/10.0f; }
    if (!isnan(vl2))    { b += ",\"voltage_l2\":";  b += vl2/10.0f; }
    if (!isnan(vl3))    { b += ",\"voltage_l3\":";  b += vl3/10.0f; }
    if (!isnan(il1))    { b += ",\"current_l1\":";  b += il1/1000.0f; }
    if (!isnan(il2))    { b += ",\"current_l2\":";  b += il2/1000.0f; }
    if (!isnan(il3))    { b += ",\"current_l3\":";  b += il3/1000.0f; }
    if (!isnan(pw))     { b += ",\"power_w\":";     b += pw; }
    if (!isnan(freq))   { b += ",\"frequency\":";   b += freq/100.0f; }
    if (!isnan(energy)) { b += ",\"energy_kwh\":";  b += energy/1000.0f; }
    b += "}";

    bool ok = httpPost("/api/readings", b);
    Serial.printf("  Backend: %s\n", ok ? "yuborildi" : "yuborilmadi");
}

// ════════════════════════════════════════════════════════════════════
// Buyruqlar (backend dan)
// ════════════════════════════════════════════════════════════════════
void pollCommands() {
    if (WiFi.status() != WL_CONNECTED) return;
    char path[80];
    snprintf(path, sizeof(path), "/api/commands/%s", cfgDeviceId);
    String resp = httpGet(path);
    if (resp.length() == 0) return;

    int idx = 0;
    while (true) {
        int idPos = resp.indexOf("\"id\":", idx);
        if (idPos < 0) break;
        int cmdId = resp.substring(idPos+5).toInt();
        int actPos = resp.indexOf("\"action\":\"", idPos);
        if (actPos < 0) break;
        actPos += 10;
        int actEnd = resp.indexOf("\"", actPos);
        String action = resp.substring(actPos, actEnd);

        const char* result = "ok";
        if (action == "relay_on") {
            if (!isConnected) autoConnect();
            bool ok = doAction(70, OBIS_RELAY, 2);
            result = ok ? "ok" : "error";
            Serial.printf("  CMD: relay_on -> %s\n", result);
        } else if (action == "relay_off") {
            if (!isConnected) autoConnect();
            bool ok = doAction(70, OBIS_RELAY, 1);
            result = ok ? "ok" : "error";
            Serial.printf("  CMD: relay_off -> %s\n", result);
        }

        char ackPath[80];
        snprintf(ackPath, sizeof(ackPath), "/api/commands/%d/ack?result=%s", cmdId, result);
        httpPost(ackPath, "{}");
        idx = actEnd + 1;
    }
}

// ════════════════════════════════════════════════════════════════════
// OTA
// ════════════════════════════════════════════════════════════════════
void checkOta() {
    if (WiFi.status() != WL_CONNECTED) return;
    char path[100];
    snprintf(path, sizeof(path), "/api/ota/check/%s?current_version=" FW_VERSION, cfgDeviceId);
    String resp = httpGet(path);
    if (resp.indexOf("\"update\":true") < 0) return;

    int urlPos = resp.indexOf("\"url\":\"");
    if (urlPos < 0) return;
    urlPos += 7;
    int urlEnd = resp.indexOf("\"", urlPos);
    String relUrl = resp.substring(urlPos, urlEnd);

    char fwUrl[200];
    snprintf(fwUrl, sizeof(fwUrl), "%s%s", SERVER_URL, relUrl.c_str());
    Serial.printf("  OTA: %s\n", fwUrl);

    HTTPClient http;
    http.begin(fwUrl);
    int code = http.GET();
    if (code == 200) {
        int len = http.getSize();
        WiFiClient* stream = http.getStreamPtr();
        if (Update.begin(len > 0 ? len : UPDATE_SIZE_UNKNOWN)) {
            Update.writeStream(*stream);
            if (Update.end() && Update.isFinished()) {
                Serial.println("  OTA: muvaffaqiyat! Qayta ishga tushmoqda...");
                delay(1000);
                ESP.restart();
            }
        }
    }
    http.end();
}

// ════════════════════════════════════════════════════════════════════
// Serial buyruqlar
// ════════════════════════════════════════════════════════════════════
void printHelp() {
    Serial.println("\n  Buyruqlar:");
    Serial.println("  connect          - hisoblagichga ulanish");
    Serial.println("  connect 4800     - 4800 baud");
    Serial.println("  disconnect       - uzish");
    Serial.println("  voltage          - kuchlanish");
    Serial.println("  current          - tok");
    Serial.println("  power            - quvvat");
    Serial.println("  energy           - energiya");
    Serial.println("  relay on/off     - rele");
    Serial.println("  status           - holat");
    Serial.println("  info             - seriya raqam");
    Serial.println("  help             - shu ro'yxat\n");
}

void execCmd(const char* cmd) {
    Serial.printf("> %s\n", cmd);

    if (strncmp(cmd,"connect",7)==0) {
        if (isConnected) doDisconnect();
        uint32_t baud = strlen(cmd)>8 ? atoi(cmd+8) : 0;
        bool ok = baud ? tryConnect(baud) : autoConnect();
        Serial.printf("  %s (%u baud, %s)\n",
                      ok ? "ULANDI!" : "ULANMADI.",
                      rs485Baud,
                      clientSrc==CLIENT_READER ? "Reader" : "Public");

    } else if (strcmp(cmd,"disconnect")==0) {
        doDisconnect(); Serial.println("  Uzildi.");

    } else if (strcmp(cmd,"voltage")==0) {
        float v1,v2,v3;
        bool ok1=getAttribute(3,OBIS_VOLT_L1,2,&v1);
        bool ok2=getAttribute(3,OBIS_VOLT_L2,2,&v2);
        bool ok3=getAttribute(3,OBIS_VOLT_L3,2,&v3);
        if (ok1) Serial.printf("  U L1: %.1fV", v1/10.0f);
        if (ok2) Serial.printf("  L2: %.1fV", v2/10.0f);
        if (ok3) Serial.printf("  L3: %.1fV\n", v3/10.0f);
        if (!ok1) Serial.println("  o'qib bo'lmadi");

    } else if (strcmp(cmd,"current")==0) {
        float i1,i2,i3;
        getAttribute(3,OBIS_CURR_L1,2,&i1);
        getAttribute(3,OBIS_CURR_L2,2,&i2);
        getAttribute(3,OBIS_CURR_L3,2,&i3);
        Serial.printf("  I L1: %.3fA  L2: %.3fA  L3: %.3fA\n",
                      i1/1000.0f, i2/1000.0f, i3/1000.0f);

    } else if (strcmp(cmd,"power")==0) {
        float p; getAttribute(3,OBIS_POWER,2,&p);
        Serial.printf("  P: %.0f W\n", p);

    } else if (strcmp(cmd,"energy")==0) {
        float e; getAttribute(3,OBIS_ENERGY,2,&e);
        Serial.printf("  Energiya A+: %.3f kWh\n", e/1000.0f);

    } else if (strcmp(cmd,"relay on")==0) {
        Serial.println(doAction(70,OBIS_RELAY,2) ? "  YOQILDI!" : "  XATO!");

    } else if (strcmp(cmd,"relay off")==0) {
        Serial.println(doAction(70,OBIS_RELAY,1) ? "  O'CHIRILDI!" : "  XATO!");

    } else if (strcmp(cmd,"status")==0) {
        Serial.printf("  Device: %s | Meter: %s\n", cfgDeviceId, cfgMeterType);
        Serial.printf("  WiFi: %s | IP: %s\n",
                      WiFi.status()==WL_CONNECTED ? "ulangan" : "uzilgan",
                      WiFi.localIP().toString().c_str());
        Serial.printf("  Server: %s\n", SERVER_URL);
        Serial.printf("  Firmware: %s | RS-485: %u baud | %s\n",
                      FW_VERSION, rs485Baud, isConnected?"ulangan":"uzilgan");

    } else if (strcmp(cmd,"info")==0) {
        Serial.print("  Seriya: ");
        if (!getAttribute(1, OBIS_SERIAL, 2, nullptr)) Serial.print("o'qib bo'lmadi");
        Serial.println();

    } else if (strcmp(cmd,"help")==0) {
        printHelp();
    } else {
        Serial.println("  Noma'lum. 'help' yozing.");
    }
}

// ════════════════════════════════════════════════════════════════════
// Setup
// ════════════════════════════════════════════════════════════════════
void setup() {
    // Faqat brownout bitini o'chirish (butun registrni 0 QILMAY)
    CLEAR_PERI_REG_MASK(RTC_CNTL_BROWN_OUT_REG, RTC_CNTL_BROWN_OUT_ENA);

    Serial.begin(115200);
    delay(1000);

    pinMode(PIN_DE, OUTPUT);
    digitalWrite(PIN_DE, LOW);
    initFcs();
    initDeviceId();

    Serial.println();
    Serial.println("=== TE71/TE73 Meter Controller v" FW_VERSION " ===");
    Serial.printf("  Device: %s | Meter: %s\n", cfgDeviceId, cfgMeterType);
    // TG0 + TG1 WDT o'chirish — to'g'ri usul (WRITE_PERI_REG registrni to'liq tozalaydi)
    // wdt_config0.en = 0 usuli noto'g'ri edi (bit 8 emas, bit 31 kerak)
    WRITE_PERI_REG(TIMG_WDTWPROTECT_REG(0), TIMG_WDT_WKEY_VALUE); // TG0 unlock
    WRITE_PERI_REG(TIMG_WDTCONFIG0_REG(0), 0);                      // TG0 WDT o'chir
    WRITE_PERI_REG(TIMG_WDTWPROTECT_REG(0), 0);                     // TG0 re-lock

    WRITE_PERI_REG(TIMG_WDTWPROTECT_REG(1), TIMG_WDT_WKEY_VALUE); // TG1 unlock
    WRITE_PERI_REG(TIMG_WDTCONFIG0_REG(1), 0);                      // TG1 WDT o'chir
    WRITE_PERI_REG(TIMG_WDTWPROTECT_REG(1), 0);                     // TG1 re-lock

    WiFi.persistent(false);
    Serial.printf("  WiFi: %s", WIFI_SSID); Serial.flush();
    WiFi.begin(WIFI_SSID, WIFI_PASS);
    Serial.println(" (begin sent)"); Serial.flush();

    int tries = 0;
    while (WiFi.status() != WL_CONNECTED && tries < 30) {
        delay(500);
        Serial.print(".");
        Serial.flush();
        tries++;
    }

    if (WiFi.status() == WL_CONNECTED) {
        Serial.printf(" OK! IP: %s\n", WiFi.localIP().toString().c_str());
        registerDevice();
    } else {
        Serial.println(" ULANMADI (offline ishlaydi)");
    }

    // RS-485
    Serial2.begin(rs485Baud, SERIAL_8N1, PIN_RX, PIN_TX);
    Serial.print("  Hisoblagich: ");
    if (autoConnect())
        Serial.printf("ulandi! (%u baud)\n", rs485Baud);
    else
        Serial.println("topilmadi.");

    printHelp();
    Serial.print("$ ");
}

// ════════════════════════════════════════════════════════════════════
// Loop
// ════════════════════════════════════════════════════════════════════
void loop() {
    // Serial monitor
    while (Serial.available()) {
        char c = Serial.read();
        if (c == '\r') continue;
        if (c == '\n') {
            cmdBuf[cmdLen] = '\0';
            if (cmdLen > 0) execCmd(cmdBuf);
            cmdLen = 0;
            Serial.print("\n$ ");
        } else if (cmdLen < sizeof(cmdBuf)-1) {
            cmdBuf[cmdLen++] = tolower((unsigned char)c);
        }
    }

    // WiFi uzilsa qayta ulash
    static unsigned long lastWifiCheck = 0;
    if (millis() - lastWifiCheck >= 30000UL) {
        lastWifiCheck = millis();
        if (WiFi.status() != WL_CONNECTED) {
            WiFi.reconnect();
        }
    }

    unsigned long now = millis();

    if (now - lastReadingMs >= READING_INTERVAL_MS) {
        lastReadingMs = now;
        readAndPost();
    }

    if (now - lastCmdPollMs >= CMD_POLL_INTERVAL_MS) {
        lastCmdPollMs = now;
        pollCommands();
    }

    if (now - lastOtaMs >= OTA_CHECK_INTERVAL_MS) {
        lastOtaMs = now;
        checkOta();
    }

    delay(10);
}
